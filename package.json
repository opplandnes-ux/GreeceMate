{
  "name": "greecemate-h5",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler pages dev . --d1 DB=greecemate-orders --persist-to .wrangler/state",
    "typecheck": "tsc --noEmit",
    "d1:migrate:local": "wrangler d1 migrations apply DB --config wrangler.local.toml --local --persist-to .wrangler/state",
    "d1:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260620.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.24.3"
  }
}
